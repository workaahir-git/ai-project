# --- Dev-console integration ---
# Shared secret for POST /generate/test (see app/main.py). Leave blank to
# keep that route disabled. Must match whatever the dev-console's
# ai_testing.py sends as X-Dev-Test-Key once that's wired up.
DEV_TEST_KEY=

# Where GET /member/login redirects to (see app/main.py). This is the
# ai-project-login Vercel deploy's real URL - project #2, NOT
# admin-dashboard-backend's separate Vercel project. Required for
# /member/login to work at all; unset -> 503.
